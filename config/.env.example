# ════════════════════════════════════════════════════════════
# .env.example — 项目三环境变量模板
# ════════════════════════════════════════════════════════════
#
# 使用方式：
#   1. 复制此文件为 .env:  cp .env.example .env
#   2. 填入真实值：   DEEPSEEK_API_KEY=sk-your-key-here
#   3. .env 已被 .gitignore 忽略，不会误提交
#
# 优先级：系统环境变量 > .env 文件
# ════════════════════════════════════════════════════════════

# ── 项目一目录（供 git 同步 + Bug 管道扫描） ───────────────
# 设置后，self_evolve_round.py 每轮会自动同步项目一并运行代码审查
# 示例（WSL）：PROJECT1_DIR=/mnt/c/Users/qjx/Desktop/agent-自进化版/项目一cursor版本/在线部分
# 示例（Linux/Mac）：PROJECT1_DIR=/home/user/projects/project1
# 示例（Windows 路径）：PROJECT1_DIR=C:/Users/qjx/Desktop/agent-自进化版/项目一cursor版本/在线部分
# PROJECT1_DIR=

# ── DeepSeek API（项目一/二的 LLM 后端） ────────────────────
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Ollama 本地模型 ─────────────────────────────────────────
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# ── GitHub 推送 ─────────────────────────────────────────────
# GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GIT_USER_NAME=
# GIT_USER_EMAIL=

# ── QQ 邮箱（AI日报推送） ───────────────────────────────────
# QQ_EMAIL=your-qq-number@qq.com
# QQ_AUTH_CODE=xxxxxxxxxxxxxxxx

# ── Hermes Gateway ──────────────────────────────────────────
# HERMES_GATEWAY_TOKEN=
# HERMES_GATEWAY_URL=http://localhost:8088

# ── 审计日志 ────────────────────────────────────────────────
# AUDIT_LOG_ENABLED=true
# AUDIT_LOG_PATH=logs/audit.jsonl
